{
  "name": "safemode",
  "version": "2.0.12",
  "description": "Stop your AI coding agent from doing something you'll regret.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "safemode": "./dist/bin/safemode.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/bin/safemode.js",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist/",
    "build:hook": "esbuild src/hooks/hook-runner.ts --bundle --platform=node --target=node18 --outfile=dist/hooks/hook-runner.bundle.js --format=esm --external:better-sqlite3 --external:@onnxruntime-node",
    "prepublishOnly": "npm run clean && npm run build && npm run build:hook"
  },
  "keywords": [
    "mcp",
    "ai-safety",
    "governance",
    "proxy",
    "cursor",
    "claude",
    "anthropic",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SafeModeAI/safemode"
  },
  "homepage": "https://safemode.run",
  "bugs": {
    "url": "https://github.com/SafeModeAI/safemode/issues"
  },
  "author": "TrustScope <hello@trustscope.ai>",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.0.7",
    "node-notifier": "^10.0.1",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/node-notifier": "^8.0.5",
    "esbuild": "^0.27.3",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}
